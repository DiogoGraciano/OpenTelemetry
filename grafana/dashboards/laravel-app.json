        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_request_duration_seconds_count{service_name=~\"$service\",http_response_status_code=~\"5..\"}[2m])) / sum(rate(http_server_request_duration_seconds_count{service_name=~\"$service\"}[2m])) * 100",
          "legendFormat": "errors %",
          "refId": "A"
        }
      ]
    },
